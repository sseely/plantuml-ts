{
  "name": "plantuml-ts",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plantuml-ts.cjs",
  "module": "./dist/plantuml-ts.js",
  "types": "./dist/plantuml-ts.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plantuml-ts.js",
      "require": "./dist/plantuml-ts.cjs"
    }
  },
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "vite build",
    "build:demo": "vite build --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.node.json --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern src tests demo",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "visual:classify": "jiti scripts/classify-corpus.ts",
    "visual:capture": "jiti scripts/capture-corpus.ts --type dot",
    "visual:build": "vite build && jiti scripts/build-pages.ts",
    "visual:upload": "jiti scripts/upload-references.ts  --type dot",
    "visual": "npm run visual:build && npx serve .",
    "svg:survey": "jiti scripts/svg-parity-survey.ts",
    "svg:dashboard": "jiti scripts/svg-parity-dashboard.ts",
    "docs:copy-reports": "node docs-site/copy-reports.mjs",
    "docs:dev": "npm run docs:copy-reports && vitepress dev docs-site",
    "docs:build": "npm run docs:copy-reports && vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site"
  },
  "dependencies": {
    "graphviz-ts": "^0.1.26071122",
    "jsonc-parser": "^3.3.1",
    "katex": "^0.16.45"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@xmldom/xmldom": "^0.9.10",
    "eslint": "^9.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^1.0.0"
  }
}
