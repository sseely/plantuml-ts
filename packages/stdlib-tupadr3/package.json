{
  "name": "@plantuml-ts/stdlib-tupadr3",
  "version": "0.1.0",
  "description": "Vendored tupadr3 PlantUML icon-font sprite bundle for plantuml-ts",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/sseely/plantuml-ts.git",
    "directory": "packages/stdlib-tupadr3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "generated",
    "licenses",
