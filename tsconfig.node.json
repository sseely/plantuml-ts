{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // DOM is needed because node-side tooling here (scripts/oracle-gap.ts)
    // imports the browser library (src/), whose measurer references DOM types.
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "moduleResolution": "Node16",
    "module": "Node16"
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "eslint.config.ts",
    "scripts/**/*.ts"
  ]
}
