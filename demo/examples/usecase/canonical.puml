@startuml
left to right direction
actor Customer as C
actor "Support Agent" as SA

rectangle "E-Commerce System" {
  usecase "Browse Products" as UC1
  usecase "Add to Cart" as UC2
  usecase "Checkout" as UC3
  usecase "Apply Discount" as UC4
  usecase "Track Order" as UC5
  usecase "Process Refund" as UC6
}

C --> UC1
C --> UC2
C --> UC3
C --> UC5
UC3 ..> UC4 : <<extend>>
UC3 ..> UC2 : <<include>>
SA --> UC6
SA --> UC5
@enduml
